# Server repo: copy to .env and fill in. Never commit .env.
# On Render/Fly: set these in the dashboard; do NOT set SYNC_ENRICH_ENABLED (or set false).

PORT=3001
MONGODB_URI=
DATABASE_NAME=integration-factor
COLLECTION_NAME=music
ADMIN_TOKEN=
# SYNC_ENRICH_ENABLED=true
# CORS_ORIGINS=
# COVER_CACHE_DIR=
# DELETED_ARTWORK_COLLECTION=deletedArtwork

# NAS (optional; leave unset in cloud)
# NAS_HOST=
# NAS_PORT=
# NAS_USER=
# NAS_PASS=

# Cloudflare Tunnel to NAS (optional; for Render to reach NAS). See docs/CLOUDFLARE_TUNNEL_NAS.md
# NAS_TUNNEL_URL=https://nas.integrationfactor.com
# CF_ACCESS_CLIENT_ID=
# CF_ACCESS_CLIENT_SECRET=

# Contact
# RESEND_API_KEY=
# CONTACT_TO_EMAIL=
# CONTACT_FROM_EMAIL=

# Enrichment (for local runs)
# MIN_CONFIDENCE_THRESHOLD=75
# THEAUDIODB_API_KEY=
# DISCOGS_CONSUMER_KEY=
# DISCOGS_CONSUMER_SECRET=
